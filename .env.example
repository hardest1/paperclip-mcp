# paperclip-mcp configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Base URL of your Paperclip instance.
# Default (local install): http://localhost:3100/api
# Change only if you have a remote or differently configured Paperclip instance.
PAPERCLIP_BASE_URL=http://localhost:3100/api

# Required — Agent API key.
# Generate in Paperclip UI: Settings → API Keys → New Key.
# Keep this secret: it grants write access to your company's data.
PAPERCLIP_API_KEY=

# Optional — Default company UUID.
# When set, all company-scoped tools use this as fallback.
# When omitted, the server starts in multi-company mode:
# use set_active_company to select a company, or pass company_id to each tool.
# Find the UUID in the Paperclip UI URL: /companies/{uuid}
# PAPERCLIP_COMPANY_ID=
